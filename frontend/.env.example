NODE_ENV=production
PORT=3000

# Backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google Integrations
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_or_dummy_key_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# Telemetry / Other External Configuration
# Provide NASA FIRMS API key if not managed purely backend
NEXT_PUBLIC_CLIMATE_TRACE_API=your_climate_trace_key_here
