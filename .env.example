# EcoSphere Global Environment Variables Template
# Copy this file to .env.local (frontend) or .env (backend) and fill in the values.
# DO NOT commit actual secrets or credentials to version control.

# ==========================================
# Application Configuration
# ==========================================
NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:8000

# ==========================================
# Google Integrations
# ==========================================
# Google Maps JavaScript API Key
GOOGLE_MAPS_API_KEY=PLACEHOLDER

# Google OAuth 2.0 Credentials (Authentication)
GOOGLE_CLIENT_ID=PLACEHOLDER
GOOGLE_CLIENT_SECRET=PLACEHOLDER

# Google Pay Merchant Identity for Carbon Marketplace
GOOGLE_PAY_MERCHANT_ID=YOUR_GOOGLE_PAY_MERCHANT_ID_PLACEHOLDER

# Google Sheets Client Configuration / Service Account credentials JSON string
GOOGLE_SHEETS_CLIENT=YOUR_GOOGLE_SHEETS_CLIENT_JSON_PLACEHOLDER

# ==========================================
# Satellite & Environmental Telemetry
# ==========================================
# NASA FIRMS API Token (Active Fire Data)
NASA_FIRMS_API=PLACEHOLDER

# Copernicus API / Sentinel Hub Credentials (NDVI & Air Quality Spec)

COPERNICUS_CLIENT_ID=PLACEHOLDER
COPERNICUS_CLIENT_SECRET=PLACEHOLDER

# Climate Trace Endpoint for Gas Spectrometry Analysis
CLIMATE_TRACE_ENDPOINT=https://api.climatetrace.org/v7/sources?year=2025&gas=co2e_100yr&sectors=&subsectors=&gadmId=&cityId=&countryGroup=&continent=&ownerIds=&limit=100&offset=0

# ==========================================
# Security & JWT Setup
# ==========================================
# Secret key for local JWT session tokens signature verification
JWT_SECRET=PLACEHOLDER
JWT_ALGORITHM=HS256

