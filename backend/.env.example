ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000

# Security & Authentication
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./ecosphere.db

# Copernicus Sentinel Hub
COPERNICUS_CLIENT_ID=your_copernicus_client_id_here
COPERNICUS_CLIENT_SECRET=your_copernicus_client_secret_here

# Google Earth Engine (GEE)
GOOGLE_APPLICATION_CREDENTIALS=path_to_service_account.json
EE_PROJECT_ID=your_ee_project_id_here

# NASA FIRMS
NASA_FIRMS_API_KEY=your_nasa_firms_map_key_here

# Redis Cache (Optional)
REDIS_URL=redis://localhost:6379
